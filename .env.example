# Copy to .env (local) or .env.production (release build).
# Required formats:
# - VITE_FIREBASE_AUTH_DOMAIN: hostname only, e.g. your-project.firebaseapp.com
# - VITE_FIREBASE_MESSAGING_SENDER_ID: numeric only, e.g. 123456789012
# - VITE_FIREBASE_STORAGE_BUCKET: bucket host, e.g. your-project.appspot.com or your-project.firebasestorage.app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
